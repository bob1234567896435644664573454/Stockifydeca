SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# The following are automatically set by the Supabase CLI
SB_URL=http://127.0.0.1:54321
SB_ANON_KEY=your_supabase_anon_key
SB_SERVICE_ROLE_KEY=your_supabase_service_role_key
SB_JWT_ISSUER=http://127.0.0.1:54321/auth/v1

# Market Data
MARKET_DATA_API_KEY=demo
ALPACA_KEY=
ALPACA_SECRET=

# Engine & Jobs
ENGINE_TICK_INTERVAL_SECONDS=30
DEFAULT_SLIPPAGE_BPS=5
DEFAULT_FEE_BPS=0
ENGINE_JOB_KEY=local_development_key
COMPETITION_JOBS_KEY=local_development_key
REPORT_JOBS_KEY=local_development_key
MARKET_DATA_JOB_KEY=local_development_key

# VITE specific env vars for frontend
VITE_SB_URL=http://127.0.0.1:54321
VITE_SB_ANON_KEY=your_supabase_anon_key
